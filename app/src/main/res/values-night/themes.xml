<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.ElectricityBillEstimator"
        parent="Theme.MaterialComponents.DayNight.DarkActionBar">

        <!-- Primary blue color for toolbar -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@color/textWhite</item>

        <!-- Accent color -->
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorOnSecondary">@color/textPrimary</item>

        <!-- Status bar color -->
        <item name="android:statusBarColor"
            tools:targetApi="l">@color/colorPrimaryDark</item>

        <!-- App background -->
        <item name="android:windowBackground">@color/backgroundColor</item>
        <item name="titleTextColor">@color/textWhite</item>
        <item name="subtitleTextColor">#B3FFFFFF</item>
        <item name="actionBarStyle">@style/CustomActionBar</item>

    </style>
    <!-- Custom Action Bar style -->
    <style name="CustomActionBar"
        parent="Widget.AppCompat.ActionBar">
        <item name="background">@color/colorPrimary</item>
        <item name="titleTextStyle">@style/CustomTitleText</item>
    </style>

    <!-- Custom title text style -->
    <style name="CustomTitleText"
        parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@color/textWhite</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
</resources>